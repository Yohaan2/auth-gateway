# ============================================================
# AUTH MANAGER — Variables de entorno
# Copia este archivo como .env y rellena los valores.
# ============================================================

# ─── Servidor Express ─────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Sesión Express (legacy) ──────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambia-este-secreto-muy-largo-en-produccion

# ─── Base de datos PostgreSQL ─────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_optrax
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_optrax

# ─── Keycloak — URLs ──────────────────────────────────────
# URL pública (accesible desde el navegador y el JWT issuer)
KEYCLOAK_URL=http://localhost:8080
# URL interna para llamadas backend→Keycloak (dentro de Docker usa el nombre del servicio)
# KEYCLOAK_INTERNAL_URL=http://keycloak:8080

KEYCLOAK_REALM=optrax-realm

# ─── Auth Manager Client (flujo de sesión legacy) ─────────
# Client "auth-manager" en Keycloak (Confidential, Standard Flow)
KEYCLOAK_CLIENT_ID=auth-manager
KEYCLOAK_CLIENT_SECRET=<client-secret-del-auth-manager>
KEYCLOAK_REDIRECT_URI=http://localhost:3000/api/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/

# ─── Service Account (Admin REST API) ─────────────────────
# Client "auth-manager-sa" en Keycloak (Service Account habilitado)
# Debe tener roles de realm-management: manage-users, manage-clients,
# manage-realm, view-users, query-groups, view-realm
KEYCLOAK_SA_CLIENT_ID=auth-manager-sa
KEYCLOAK_SA_CLIENT_SECRET=<client-secret-del-service-account>

# ─── Roles internos del panel ─────────────────────────────
KEYCLOAK_ADMIN_ROLE=auth-manager-admin
KEYCLOAK_VIEWER_ROLE=auth-manager-viewer

# ─── Frontend Vite (copiados a client/.env.local) ─────────
# VITE_KEYCLOAK_URL=http://localhost:8080
# VITE_KEYCLOAK_REALM=optrax-realm
# VITE_KEYCLOAK_CLIENT_ID=auth-manager-frontend
# VITE_ADMIN_ROLE=auth-manager-admin
# VITE_VIEWER_ROLE=auth-manager-viewer
