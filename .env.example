# ==========================================
# CONFIGURACIÓN GENERAL DE LA APLICACIÓN
# ==========================================
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Secretos de Sesión (usados por express-session)
SESSION_SECRET=super-secret-session-key-change-in-production

# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS (POSTGRES)
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_optrax
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_optrax

# ==========================================
# CONFIGURACIÓN DE KEYCLOAK
# ==========================================
# URL de Keycloak accesible desde el navegador del usuario (frontend) y backend
KEYCLOAK_URL=http://localhost:8080

# URL de Keycloak accesible dentro de la red de Docker (si difiere de KEYCLOAK_URL)
# Útil si el contenedor 'app' necesita comunicarse con el contenedor 'keycloak' internamente
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# Realm de Keycloak a utilizar
KEYCLOAK_REALM=optrax-realm

# Cliente de Keycloak configurado para flujo Authorization Code con Client Secret
KEYCLOAK_CLIENT_ID=optrax-app
KEYCLOAK_CLIENT_SECRET=cambiar-por-client-secret-de-keycloak

# URLs de redirección de Auth
KEYCLOAK_REDIRECT_URI=http://localhost:3000/api/auth/callback
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/
